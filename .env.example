# PostgreSQL connection string
# Homebrew Postgres on macOS typically uses your system username (no password).
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/collab_editor?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# Production deployments should set this to the public app URL.
# Example: https://your-domain.com
AUTH_URL="http://localhost:3000"

# Optional AI features. Leave empty to use the local fallback responses.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

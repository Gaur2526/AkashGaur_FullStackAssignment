# PostgreSQL connection string used by the running app.
# Local example: Homebrew Postgres on macOS typically uses your system username.
# Supabase/Vercel example: use the transaction pooler on port 6543 with pgbouncer=true.
# If the URL already has query params, append pgbouncer=true with & instead of ?.
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/collab_editor?schema=public"

# Direct database URL for Prisma migrations in hosted Postgres providers.
# For Supabase, use the direct connection or session pooler URL on port 5432 here.
# Do not add pgbouncer=true to DIRECT_URL.
DIRECT_URL="postgresql://YOUR_USER@localhost:5432/collab_editor?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# Production deployments should set this to the public app URL.
# Example: https://your-domain.com
AUTH_URL="http://localhost:3000"

# Optional AI features. Leave empty to use the local fallback responses.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
